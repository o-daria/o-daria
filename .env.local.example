# Environment variables for local full-stack testing.
# Used by: docker-compose.local.yml
#
# Setup:
#   cp .env.local.example .env.local
#   Fill in GOOGLE_CLIENT_ID and ANTHROPIC_API_KEY
#   docker compose -f docker-compose.local.yml up --build

# ── Google OAuth ───────────────────────────────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
# Authorized JavaScript origins: http://localhost:8080
# Authorized redirect URIs: http://localhost:8080
GOOGLE_CLIENT_ID=

# ── Anthropic ─────────────────────────────────────────────────────────────────
# Required by the BE pipeline (Claude API calls)
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional: Apify (only needed if not using pre-scraped profiles/) ───────────
# APIFY_TOKEN=apify_api_...

# ── BE auth (dev fallback — still works alongside Google Sign-In) ─────────────
API_KEY=local-dev-key
TENANT_ID=local-tenant

# ── S3 image storage (optional for local testing) ─────────────────────────────
# Leave blank to skip image upload mode
S3_IMAGES_BUCKET=
AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
