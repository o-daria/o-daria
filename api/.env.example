# Required — external APIs
ANTHROPIC_API_KEY=
APIFY_TOKEN=

# Embeddings — choose one provider:
#   ollama (default, free)  — requires Ollama running locally or in Docker
#   openai                  — requires OPENAI_API_KEY
EMBEDDING_PROVIDER=ollama
# EMBEDDING_BASE_URL=http://localhost:11434/v1   # default for local Ollama; Docker overrides this
# EMBEDDING_MODEL=nomic-embed-text               # default for Ollama
# OPENAI_API_KEY=sk-...                          # only needed if EMBEDDING_PROVIDER=openai

# Required — app auth
API_KEY=
TENANT_ID=

# Google OAuth — required for Google Sign-In
GOOGLE_CLIENT_ID=

# CORS — add the deployed FE URL so CloudFront requests are allowed
FRONTEND_URL=

# S3 image storage — required for image upload mode
S3_IMAGES_BUCKET=
AWS_REGION=
# Local dev only — on EC2, IAM instance role is used instead
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Set automatically by docker-compose (leave blank here, override only if running outside Docker)
DATABASE_URL=

PORT=