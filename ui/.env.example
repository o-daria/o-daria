# ─── Google OAuth ────────────────────────────────────────────────────────────
# Google OAuth 2.0 Web Client ID — create at https://console.cloud.google.com/
# Baked into the bundle at build time via webpack DefinePlugin (never runtime-fetched)
GOOGLE_CLIENT_ID=

# ─── External API ────────────────────────────────────────────────────────────
# Base URL of the external audience analysis + Canva backend API
VITE_API_BASE_URL=https://api.example.com

# ─── Module Federation Remote URLs ───────────────────────────────────────────
# Set these to the deployed CloudFront URLs for each MFE remoteEntry.js
VITE_MFE_AUTH_URL=https://<cf-domain>/mfe-auth/remoteEntry.js
VITE_MFE_PROJECTS_URL=https://<cf-domain>/mfe-projects/remoteEntry.js
VITE_MFE_REPORTS_URL=https://<cf-domain>/mfe-reports/remoteEntry.js
VITE_MFE_CANVA_URL=https://<cf-domain>/mfe-canva/remoteEntry.js
